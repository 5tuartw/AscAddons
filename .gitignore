# AscAddons - WoW 3.3.5 Addons for Ascension
# Strategy: Whitelist only ready addons, screenshots, and releases

# Ignore all by default
/*

# Allow these top-level items
!.gitignore
!README.md
!LICENSE
!.github/
!addon_manager/
!addon_updater.py
!addon_updater_config.json
!addons/
!create_release.sh
!requirements.txt
!scripts/

# Whitelist first-party addon directories
!addons/**

# Track addon manager and script source files
!addon_manager/**
!scripts/**

# Ignore generated/runtime addon manager artifacts
addon_manager/backups/
addon_manager/temp/
addon_manager/.venv/
addon_manager/venv/
addon_manager/**/__pycache__/
addon_manager/*.log

# Whitelist screenshots and releases
!screenshots/
!screenshots/**
!releases/
!releases/**

# Workspace-only (keep excluded)
archive/
data/
temp/
tools/
tools/venv/
libraries/
private/
docs/

# Common junk
*.bak
*.tmp
*.swp
*.orig
*.rej
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# IDE / editor metadata
.vscode/
.idea/
*.iml

# Lua dev artifacts (if any future tooling)
luac.out